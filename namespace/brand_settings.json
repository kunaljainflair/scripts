    {
      "type": "SINGLE",
      "context": [{ "page": "brand_settings", "section": "general" }],
      "key": "info.workflow_rules",
      "sub_keys": [],
      "en": { "defaultValue": "Tasks can be automated based on workflow rules. Priority and status changes may trigger notifications to assignees. Overdue tasks are escalated automatically." },
      "ar": { "defaultValue": "يمكن أتمتة المهام بناءً على قواعد سير العمل. قد تؤدي تغييرات الأولوية والحالة إلى إطلاق إشعارات للمعينين. يتم تصعيد المهام المتأخرة تلقائيًا." },
      "es": { "defaultValue": "Las tareas se pueden automatizar según las reglas de flujo de trabajo. Los cambios de prioridad y estado pueden activar notificaciones para los asignados. Las tareas vencidas se escalan automáticamente." },
      "id": { "defaultValue": "Tugas dapat diotomatiskan berdasarkan aturan alur kerja. Perubahan prioritas dan status dapat memicu notifikasi kepada penerima tugas. Tugas yang terlambat ditingkatkan secara otomatis." },
      "ja": { "defaultValue": "タスクはワークフロールールに基づいて自動化できます。優先度やステータスの変更により通知がトリガーされる場合があります。期限を過ぎたタスクは自動的にエスカレーションされます。" },
      "ko": { "defaultValue": "워크플로 규칙에 따라 작업을 자동화할 수 있습니다. 우선순위 및 상태 변경 시 알림이 전송될 수 있습니다. 기한이 지난 작업은 자동으로 에스컬레이션됩니다." },
      "ms": { "defaultValue": "Tugas boleh diautomasikan berdasarkan peraturan aliran kerja. Perubahan keutamaan dan status boleh mencetuskan pemberitahuan kepada penerima tugas. Tugas tertunggak ditingkatkan secara automatik." },
      "th": { "defaultValue": "งานสามารถทำให้เป็นอัตโนมัติได้ตามกฎเวิร์กโฟลว์ การเปลี่ยนสถานะอาจทำให้เกิดการแจ้งเตือน งานที่เกินกำหนดจะถูกยกระดับโดยอัตโนมัติ" },
      "vi": { "defaultValue": "Các tác vụ có thể được tự động hóa dựa trên quy tắc. Thay đổi trạng thái có thể kích hoạt thông báo. Các tác vụ quá hạn sẽ được xử lý tự động." }
    },

